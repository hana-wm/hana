### Example config.toml with Dual-Title Feature ###

### NEW: Dual-Window Title Display
# When you have 2+ windows in a workspace, the title segment
# splits in half to show both window titles side-by-side!
#
# Configuration options:
# - title_left: Accent color for left half (primary window)
# - title_right: Accent color for right half (secondary window)
#
# Window selection (left to right in bar):
# 1. Primary (left): Leftmost window, or topmost if tied
# 2. Secondary (right): Second window by same criteria

[bar]
enabled = true
position = "bottom"

fonts = [
    "FiraCode Nerd Font Propo Ret",
    "Noto Sans CJK JP",
]

font_size = 16%
segment_spacing = 8%
height = 60
padding = 99
transparency = 0%

# Main color palette
bg = "#0d0d14"
fg = "#ebd9bc"

selected_bg = "#ac3232"
selected_fg = "#eeeeee"
occupied_fg = "#eeeeee"
urgent_bg   = "#FF0000"
urgent_fg   = "#FFFFFF"

# Default accent for all segments
accent_color = "#ac3232"

# Workspace settings
icons = ["あ", "か", "い", "は", "な", "つ", "ん", "で"]
workspace_width = 125%
indicator_size = 150%

# Per-segment accent colors
# This section lets you customize colors for each segment individually
[bar.colors]
workspaces = "#b9c0a8"  # Workspace indicators

# Title segment colors
title = "#ac3232"        # Used for single-window mode
title_left = "#61afef"   # NEW: Left half in dual-title mode (blue)
title_right = "#e06c75"  # NEW: Right half in dual-title mode (red)

clock = "#ac3232"        # Clock segment

# Alternative symmetric dual-title (same color both sides):
# title_left = "#ac3232"
# title_right = "#ac3232"

# Alternative gradient dual-title:
# title_left = "#e06c75"   # Red
# title_right = "#61afef"  # Blue

# Color scheme examples for dual-title:
#
# 1. Fire & Ice:
#   title_left = "#ff6b6b"   # Warm red
#   title_right = "#4ecdc4"  # Cool cyan
#
# 2. Forest:
#   title_left = "#2ecc71"   # Green
#   title_right = "#27ae60"  # Dark green
#
# 3. Sunset:
#   title_left = "#f39c12"   # Orange
#   title_right = "#e74c3c"  # Red
#
# 4. Ocean:
#   title_left = "#3498db"   # Light blue
#   title_right = "#2980b9"  # Dark blue

# Bar layout (unchanged)
[bar.layout.left]
segments = ["workspaces", "layout"]

[bar.layout.center]
segments = ["title"]  # This is where dual-title magic happens!

[bar.layout.right]
segments = ["clock"]

[bar.modules.workspaces]
count = 8

# Rest of config (tiling, binds, etc.) remains the same...
[tiling]
enabled = true
layouts = ["master-stack", "monocle", "grid"]

[tiling.aesthetics]
gaps             = 2.5%
border_width     = 1%
border_focused   = '#ac3232'
border_unfocused = '#52263e'

[tiling.layouts.master-stack]
count = 1
side  = "left"
width = 50%

[binds]
Mod = "Super"
kill = "pkill -9"

# WM interactions
Mod+F = "toggle_fullscreen"
Mod+Shift+Return = "{kill} Xorg"
Mod+Shift+F = "close_window"
Mod+Shift+T = "reload"

# Tiling
Mod+N           = "toggle_tiling"
Mod+space       = "toggle_layout"
Mod+Shift+space = "toggle_layout_reverse"
Mod+Tab         = "swap_master"

# Layouts
Mod+H      = "decrease_master" 
Mod+L      = "increase_master"
Mod+comma  = "increase_master_count"
Mod+period = "decrease_master_count" 

# Workspaces
Mod+1 = "workspace_1"
Mod+2 = "workspace_2"
Mod+3 = "workspace_3"
Mod+4 = "workspace_4"
Mod+Q = "workspace_5"
Mod+W = "workspace_6"
Mod+E = "workspace_7"
Mod+R = "workspace_8"

# Move window to workspace
Mod+Shift+1 = "move_to_workspace_1"
Mod+Shift+2 = "move_to_workspace_2"
Mod+Shift+3 = "move_to_workspace_3"
Mod+Shift+4 = "move_to_workspace_4"
Mod+Shift+Q = "move_to_workspace_5"
Mod+Shift+W = "move_to_workspace_6"
Mod+Shift+E = "move_to_workspace_7"
Mod+Shift+R = "move_to_workspace_8"

# Bar
Mod+B = "toggle_bar_visibility"
Mod+Shift+B = "toggle_bar_position"

# Applications
Mod+P = "rofi -show drun"
Mod+A = "MOZ_USE_XINPUT2=1 firefox"
Mod+s = "flatpak run org.equicord.equibop"
Mod+d = "ghostty"
Mod+X = "~/Games/t-client/DDNet"
Mod+c = "flatpak run com.valvesoftware.Steam"
Mod+V = "flatpak run com.github.th_ch.youtube_music"

# Emergency
Mod+Shift+Escape = "emergency_recover"

# Workspace rules
[workspace.rules.1]
Navigator
Firefox

[workspace.rules.2]
discord
vesktop
equibop
electron

[workspace.rules.3]
com.github.th_ch.youtube_music

[workspace.rules.4]
OpenTabletDriver.UX

[workspace.rules.5]
"osu!"
DDNet

[workspace.rules.6]
emacs
xeyes

[workspace.rules.7]
freetube
gimp

[workspace.rules.8]
deluge
